---
import QRCode from "qrcode";

const TWITTER_URL = "https://twitter.com/yangniao2323";
// PNG data URI としてビルド時に生成 (SVG は Tailwind の stroke リセットと干渉するため)
const qrDataUrl = await QRCode.toDataURL(TWITTER_URL, {
    width: 320,
    margin: 2,
    color: { dark: "#000000", light: "#ffffff" },
});
---

<div class="group relative" data-qr-container>
    <!-- Card (group-hover で Card の hover: と同じ効果を再現) -->
    <a
        href="/sns/twitter"
        target="_blank"
        class="bg-white dark:bg-gray-800 p-8 rounded-xl shadow-lg group-hover:shadow-xl transition-all duration-300 text-center block group-hover:-translate-y-2 border border-gray-100 dark:border-gray-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 focus:-translate-y-2 focus:shadow-xl"
    >
        <div class="text-5xl mb-4 flex justify-center">
            <img
                src="/icon.png"
                alt="Twitter Icon"
                class="w-12 h-12 rounded-full shadow-lg"
            />
        </div>
        <h3 class="text-xl font-semibold mb-2 text-gray-800 dark:text-white">
            Twitter
        </h3>
        <p class="text-gray-600 dark:text-gray-300 leading-relaxed">
            @yangniao2323
        </p>
    </a>

    <!-- QR ボタン＋パネルをまとめて translate (カードと同期) -->
    <div
        class="absolute top-3 right-3 group-hover:-translate-y-2 group-focus-within:-translate-y-2 transition-all duration-300"
    >
        <button
            data-qr-toggle
            aria-expanded="false"
            aria-label="QR コードを表示"
            class="p-1.5 rounded-lg bg-gray-100 dark:bg-gray-700 text-gray-400 opacity-50 group-hover:opacity-100 group-focus-within:opacity-100 aria-expanded:opacity-100 hover:text-sky-500 dark:hover:text-sky-400 hover:bg-sky-50 dark:hover:bg-sky-950 transition-all duration-300"
        >
            <svg
                class="w-4 h-4"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                aria-hidden="true"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z"
                ></path>
            </svg>
        </button>

        <!-- QR パネル -->
        <div
            data-qr-panel
            class="hidden absolute right-0 top-9 z-20 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl shadow-xl p-3 w-80"
            role="dialog"
            aria-label="Twitter QR コード"
        >
            <div class="rounded-lg overflow-hidden bg-white">
                <img
                    src={qrDataUrl}
                    alt="Twitter プロフィールの QR コード"
                    class="w-full aspect-square"
                />
            </div>
            <p
                class="text-xs text-center mt-2 text-gray-500 dark:text-gray-400 font-mono"
            >
                @yangniao2323
            </p>
        </div>
    </div>
</div>

<script>
    document
        .querySelectorAll<HTMLElement>("[data-qr-container]")
        .forEach((container) => {
            const btn =
                container.querySelector<HTMLButtonElement>("[data-qr-toggle]");
            const panel =
                container.querySelector<HTMLElement>("[data-qr-panel]");
            if (!btn || !panel) return;

            btn.addEventListener("click", (e) => {
                e.stopPropagation();
                const opening = panel.classList.contains("hidden");
                panel.classList.toggle("hidden", !opening);
                btn.setAttribute("aria-expanded", String(opening));
            });
        });

    document.addEventListener("click", () => {
        document
            .querySelectorAll<HTMLElement>("[data-qr-container]")
            .forEach((container) => {
                const btn =
                    container.querySelector<HTMLButtonElement>(
                        "[data-qr-toggle]",
                    );
                const panel =
                    container.querySelector<HTMLElement>("[data-qr-panel]");
                if (!btn || !panel) return;
                panel.classList.add("hidden");
                btn.setAttribute("aria-expanded", "false");
            });
    });
</script>
