---
import ExpandableCard from "./ExpandableCard.astro";

const badgeClasses = {
    primary:
        "bg-primary-100 dark:bg-primary-900 text-primary-700 dark:text-primary-300",
    blue: "bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-300",
    emerald:
        "bg-emerald-100 dark:bg-emerald-900 text-emerald-700 dark:text-emerald-300",
    secondary:
        "bg-secondary-100 dark:bg-secondary-900 text-secondary-700 dark:text-secondary-300",
} as const;

type BadgeColor = keyof typeof badgeClasses;

export interface Props {
    title: string;
    badge: string;
    badgeColor?: BadgeColor;
    period?: string;
    summary: string;
    tags: string[];
}

const {
    title,
    badge,
    badgeColor = "primary",
    period,
    summary,
    tags,
} = Astro.props;

const badgeClass = badgeClasses[badgeColor];
---

<ExpandableCard>
    <div
        slot="trigger"
        class="p-5 rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 shadow-sm hover:shadow-md transition-shadow"
    >
        <div
            class="flex flex-wrap items-start justify-between gap-x-4 gap-y-1 mb-2"
        >
            <div class="flex flex-wrap items-center gap-2">
                <h3
                    class="text-base font-semibold text-gray-800 dark:text-white"
                >
                    {title}
                </h3>
                <span
                    class:list={[
                        "text-xs px-2 py-0.5 rounded-full font-medium",
                        badgeClass,
                    ]}
                >
                    {badge}
                </span>
            </div>
            {
                period && (
                    <span class="text-xs text-gray-400 dark:text-gray-500 whitespace-nowrap">
                        {period}
                    </span>
                )
            }
        </div>
        <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">
            {summary}
        </p>
        <div class="flex flex-wrap gap-1.5">
            {
                tags.map((tag) => (
                    <span class="text-xs px-2 py-0.5 rounded-full border border-gray-300 dark:border-gray-600 text-gray-600 dark:text-gray-400">
                        {tag}
                    </span>
                ))
            }
        </div>
    </div>
    <slot />
</ExpandableCard>
