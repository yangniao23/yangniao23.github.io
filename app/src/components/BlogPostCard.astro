---
export interface Props {
    title: string;
    abstract: string;
    date: string;
    href: string;
    ogp?: string;
    tags?: string[];
}

const { title, abstract, date, href, ogp, tags = [] } = Astro.props;
---

<a
    href={href}
    class="group flex flex-col sm:flex-row gap-0 sm:gap-6 bg-white dark:bg-gray-800 rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-1 border border-gray-100 dark:border-gray-700"
>
    <!-- 左: OGP 画像 -->
    <div class="sm:w-56 md:w-64 flex-shrink-0">
        {
            ogp ? (
                <img
                    src={ogp}
                    alt={title}
                    class="w-full h-48 sm:h-full object-cover"
                    loading="lazy"
                />
            ) : (
                <div class="w-full h-48 sm:h-full bg-gradient-to-br from-primary-400 to-secondary-500 flex items-center justify-center min-h-[10rem]">
                    <span class="text-white text-4xl opacity-80">📝</span>
                </div>
            )
        }
    </div>

    <!-- 右: タイトル + abstract -->
    <div
        class="flex-1 p-5 sm:py-6 sm:pr-6 sm:pl-0 flex flex-col justify-center gap-3"
    >
        <div
            class="flex items-center gap-3 text-xs text-gray-500 dark:text-gray-400"
        >
            <time>{date}</time>
            {
                tags.length > 0 && (
                    <div class="flex gap-1.5 flex-wrap">
                        {tags.map((tag) => (
                            <span class="bg-primary-50 dark:bg-primary-900/40 text-primary-600 dark:text-primary-300 px-2 py-0.5 rounded-full text-[0.7rem] font-medium">
                                {tag}
                            </span>
                        ))}
                    </div>
                )
            }
        </div>
        <h2
            class="text-lg md:text-xl font-bold text-gray-800 dark:text-white group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors duration-200 leading-snug"
        >
            {title}
        </h2>
        {
            abstract && (
                <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed line-clamp-2">
                    {abstract}
                </p>
            )
        }
    </div>
</a>
